{
    "name": "anywhen",
    "version": "0.1.0",
    "description": "Lightweight human date formatting for any locale. Zero deps, native Intl.",
    "type": "module",
    "main": "./dist/index.cjs",
    "module": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
        ".": {
            "import": "./dist/index.js",
            "require": "./dist/index.cjs",
            "types": "./dist/index.d.ts"
        }
    },
    "files": [
        "dist"
    ],
    "scripts": {
        "build": "tsdown",
        "test": "vitest run",
        "test:coverage": "npx vitest run --coverage",
        "typecheck": "tsc --noEmit",
        "release": "npm version patch && git push --follow-tags"
    },
    "keywords": [
        "intl",
        "date",
        "time",
        "i18n",
        "relative",
        "format",
        "lightweight",
        "when",
        "ago"
    ],
    "license": "MIT",
    "devDependencies": {
        "@vitest/coverage-v8": "^3.2.4",
        "typescript": "^5.9.3",
        "tsdown": "^0.21.4",
        "vitest": "^3.2.4"
    },
    "repository": {
        "type": "git",
        "url": "git+https://github.com/kirilinsky/anywhen.git"
    },
    "author": "Kirilinsky (https://github.com/kirilinsky)",
    "bugs": {
        "url": "https://github.com/kirilinsky/anywhen/issues"
    },
    "homepage": "https://github.com/kirilinsky/anywhen#readme"
}